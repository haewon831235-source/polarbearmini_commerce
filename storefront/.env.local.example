# Copy to .env.local and fill in from the Supabase dashboard.
# .env.local is gitignored — never commit real keys.

# Project Settings → Data API (or API):  Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Project Settings → API Keys:  anon / public key (safe for the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Project Settings → Database → Connection string → URI (contains the DB password).
# Used ONLY by `npm run db:setup` to create tables + seed. Server-side only.
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT-ref.supabase.co:5432/postgres

# Project Settings → API Keys:  service_role / secret key.
# SERVER-ONLY — never prefix with NEXT_PUBLIC_, never expose to the browser.
# Powers the /admin dashboard (reads orders + visitors, writes payment/visitor
# logs) and bypasses RLS. Admin features stay dormant until this is set.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---------------------------------------------------------------------------
# Admin dashboard (/admin) — uses Supabase Auth. After setting the keys above
# and running `npm run db:setup`, create the first admin:
#   1) Supabase Studio → Authentication → Users → Add user (email + password)
#   2) SQL:  insert into admin_user (user_id, email)
#            values ('<that user's auth.users.id>', '<email>');
